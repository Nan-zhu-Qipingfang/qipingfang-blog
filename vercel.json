{
  "version": 2,
  "name": "七平方の Blog",
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "^/css/(.*)$",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      },
      "dest": "/css/$1"
    },
    {
      "src": "^/js/(.*)$",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      },
      "dest": "/js/$1"
    },
    {
      "src": "^/posts/(.*)$",
      "dest": "/posts/$1"
    },
    {
      "src": "^/(.*)$",
      "dest": "/$1"
    }
  ]
}
